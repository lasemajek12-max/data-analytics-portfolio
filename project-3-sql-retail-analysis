  <h2>Sample Query — RFM Segmentation</h2>
  <div class="code-section">
    <div class="code-header">
      <div class="code-dots">
        <div class="code-dot" style="background:#ff5f56"></div>
        <div class="code-dot" style="background:#ffbd2e"></div>
