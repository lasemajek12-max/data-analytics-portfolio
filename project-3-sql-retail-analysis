      <div class="code-filename">📄 retail_sales_analysis.sql · Query 03</div>
    </div>
<pre><span class="cm">-- Customer RFM Segmentation (Recency · Frequency · Monetary)</span>
<span class="cm">-- Classifies every customer into actionable retention segments</span>

<span class="kw">WITH</span> customer_spend <span class="kw">AS</span> (
  <span class="kw">SELECT</span>
    c.customer_id,
    c.name,
    c.loyalty_tier,
    <span class="fn">COUNT</span>(<span class="kw">DISTINCT</span> t.txn_id)             <span class="kw">AS</span> total_transactions,
    <span class="fn">ROUND</span>(<span class="fn">SUM</span>(ti.quantity * ti.unit_price
          * (<span class="num">1</span> - ti.discount_pct / <span class="num">100</span>)), <span class="num">2</span>)  <span class="kw">AS</span> lifetime_value,
    <span class="fn">MAX</span>(t.txn_date)                         <span class="kw">AS</span> last_purchase_date
  <span class="kw">FROM</span> customers c
  <span class="kw">JOIN</span> transactions t       <span class="kw">ON</span> c.customer_id = t.customer_id
  <span class="kw">JOIN</span> transaction_items ti <span class="kw">ON</span> t.txn_id      = ti.txn_id
  <span class="kw">GROUP BY</span> c.customer_id, c.name, c.loyalty_tier
)
<span class="kw">SELECT</span>
  customer_id, name, lifetime_value,
  <span class="kw">CASE</span>
    <span class="kw">WHEN</span> lifetime_value &gt;= <span class="num">5000</span> <span class="kw">AND</span> total_transactions &gt;= <span class="num">20</span> <span class="kw">THEN</span> <span class="str">'Champion'</span>
    <span class="kw">WHEN</span> lifetime_value &gt;= <span class="num">2500</span> <span class="kw">AND</span> total_transactions &gt;= <span class="num">10</span> <span class="kw">THEN</span> <span class="str">'Loyal'</span>
    <span class="kw">WHEN</span> lifetime_value &gt;= <span class="num">1000</span>                              <span class="kw">THEN</span> <span class="str">'Promising'</span>
    <span class="kw">WHEN</span> last_purchase_date &lt; <span class="fn">CURRENT_DATE</span> - <span class="kw">INTERVAL</span> <span class="str">'90 days'</span> <span class="kw">THEN</span> <span class="str">'At Risk'</span>
    <span class="kw">ELSE</span> <span class="str">'New / Occasional'</span>
  <span class="kw">END</span> <span class="kw">AS</span> customer_segment
<span class="kw">FROM</span> customer_spend
<span class="kw">ORDER BY</span> lifetime_value <span class="kw">DESC</span>;</pre>
